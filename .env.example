# =============================================================================
# NTN-MEM 环境变量配置模板
# 复制为 .env 并填入实际值
# =============================================================================

# ---- 服务基础 ----
NTN_MEM_HOST=0.0.0.0
NTN_MEM_PORT=8081

# ---- 数据库 ----
# SQLite 持久化路径（默认 /data/mem.db）
NTN_MEM_DB=/data/mem.db

# ---- 向量存储 (Qdrant) ----
NTN_QDRANT_URL=http://10.69.68.15:6333

# ---- LLM / 嵌入提供方 ----
# provider: openai | siliconflow | ollama | custom
NTN_MEM_PROVIDER=openai

# OpenAI / 兼容 API 地址
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here

# 嵌入模型（默认 BAAI/bge-m3）
NTN_MEM_EMBED_MODEL=BAAI/bge-m3

# LLM 模型（用于 recollect 等分析任务）
NTN_MEM_LLM_MODEL=gemini-2.0-flash-lite

# ---- 跨容器任务通道 ----
NTN_AGENTS_SQL_HTTP=http://10.69.68.143:8085

# ---- 可选：数据目录映射（Docker） ----
# NTN_MEM_DATA=/data/mem
