# =============================================================================
# secrets.env.example —— 凭证环境变量模板
#
# 约定:
#   - 凭证唯一来源 = systemd EnvironmentFile=/etc/ntn-agents/secrets.env
#   - 真实文件权限:0600 ntn:ntn；绝不提交真实凭证
#   - 占位形式:<填这里>；部署期由人/运维填入，代码不读默认值
#   - YAML/HOCON/命令行参数不承载凭证
#   - 8 个业务角色中只有 laohao 有长链接 BotID/Secret；8 个角色均可配置短 webhook URL
#   - 不配置独立审批 BotID/Secret；审批提醒/回复走 laohao WebSocket 交互通道
#
# 部署步骤:
#   sudo install -d -m 0750 -o ntn -g ntn /etc/ntn-agents
#   sudo install -m 0600 -o ntn -g ntn ops/config/secrets.env.example /etc/ntn-agents/secrets.env
#   sudo nano /etc/ntn-agents/secrets.env   # 把 <填这里> 改掉
# =============================================================================

# ---- 长链接:仅老郝/laohao ----------------------------------------------------
WECOM_LAOHAO_BOTID=<填这里>
WECOM_LAOHAO_SECRET=<填这里>

# ---- 短 webhook:8 个业务角色 -------------------------------------------------
NTN_WECOM_WEBHOOK_LAOHAO_URL=<填这里>
NTN_WECOM_WEBHOOK_XIAOK_URL=<填这里>
NTN_WECOM_WEBHOOK_XIAOZHOU_URL=<填这里>
NTN_WECOM_WEBHOOK_LAOLI_URL=<填这里>
NTN_WECOM_WEBHOOK_LAOCHEN_URL=<填这里>
NTN_WECOM_WEBHOOK_LAOSUN_URL=<填这里>
NTN_WECOM_WEBHOOK_LAOWANG_URL=<填这里>
NTN_WECOM_WEBHOOK_LAOZHANG_URL=<填这里>

# ---- SSH:跨容器调 ccb 子进程 ------------------------------------------------
NTN_SSH_HOST=<填这里>
NTN_SSH_USER=ntn
NTN_SSH_KEY_PATH=/etc/ntn-agents/keys/laozhang_id_ed25519

# ---- mem0:可选 provider adapter；生产可不用 --------------------------------
MEM0_HOST=<填这里>
MEM0_API_KEY=<填这里>

# ---- MEM embedding: OpenAI-compatible / SiliconFlow 嵌入式模型 -------------
# API Key 只允许放在 /etc/ntn-agents/secrets.env 这类 0600 secret 文件中
NTN_MEM_EMBEDDING_PROVIDER=openai
NTN_MEM_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
NTN_MEM_EMBEDDING_MODEL=text-embedding-ada-002
NTN_MEM_EMBEDDING_API_KEY=<填这里>
NTN_MEM_EMBEDDING_TIMEOUT=15

# ---- 接入对象 UUID(OpenClaw 收消息白名单) -----------------------------------
NTN_UUID_LAOHAO=<填这里>
NTN_UUID_XIAOK=<填这里>
NTN_UUID_XIAOZHOU=<填这里>
NTN_UUID_LAOLI=<填这里>
NTN_UUID_LAOCHEN=<填这里>
NTN_UUID_LAOSUN=<填这里>
NTN_UUID_LAOWANG=<填这里>
NTN_UUID_LAOZHANG=<填这里>
